# ─── Subbrain ────────────────────────────────────────────
{domain} {
    # ─── Public API (Bearer token auth in app) ──────────────
    handle /v1/chat/completions {
        reverse_proxy localhost:4000 {
            flush_interval -1
            transport http {
                response_header_timeout 120s
            }
        }
    }
    handle /v1/autonomous {
        reverse_proxy localhost:4000 {
            flush_interval -1
            transport http {
                response_header_timeout 300s
            }
        }
    }
    handle /v1/* {
        reverse_proxy localhost:4000
    }
    handle /mcp/* {
        reverse_proxy localhost:4000
    }
    handle /health {
        reverse_proxy localhost:4000
    }

    # ─── Protected routes (basic auth) ──────────────────────
    handle /metrics {
        basicauth {
            {auth_user} {auth_hash}
        }
        reverse_proxy localhost:4000
    }
    handle /api/* {
        basicauth {
            {auth_user} {auth_hash}
        }
        reverse_proxy localhost:4000
    }

    # ─── Nuxt frontend (basic auth) ─────────────────────────
    handle {
        basicauth {
            {auth_user} {auth_hash}
        }
        reverse_proxy localhost:3000
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    log {
        output file /var/log/caddy/subbrain.log
        format json
    }
}
