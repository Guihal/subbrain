# ─── Required ─────────────────────────────────────────────
PROXY_AUTH_TOKEN=subbrain-local-dev
PROXY_PORT=4000
DB_PATH=/data/subbrain.db

# ─── Autonomous TeamLead ─────────────────────────────────
# In production it defaults to enabled. Set false to disable.
# AUTONOMOUS_ENABLED=true
# AUTONOMOUS_INTERVAL_MINUTES=15
# AUTONOMOUS_MAX_STEPS=8
# AUTONOMOUS_TASK=Custom autonomous prompt

# ─── LLM Providers ───────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxx
OPENROUTER_API_KEY=sk-or-v1-xxx

# ─── Telegram (for bot & MTProto) ────────────────────────
# Get API ID + Hash at https://my.telegram.org/apps
# TG_API_ID=12345678
# TG_API_HASH=abcdef1234567890abcdef1234567890
#
# Create bot via @BotFather
# TG_BOT_TOKEN=123456:ABC-xxx
#
# Your personal chat ID (get from @userinfobot)
# TG_OWNER_CHAT_ID=123456789
#
# HTTP/SOCKS5 proxy for Telegram API (bypass RKN blocks)
# TG_API_ROOT=https://your-proxy-server:9999
# TG_API_PROXY_KEY=your-secret-key
#
# Webhook URL (auto-set on startup): https://yourdomain.com/telegram/webhook
# TG_WEBHOOK_URL=https://subbrain.dmtr.ru/telegram/webhook
# TG_WEBHOOK_SECRET=random-secret-string
#
# Or use polling for local dev (no webhook needed)
# TG_POLLING=true
#
# MTProto userbot session (run `bun scripts/tg-login.ts` to get)
# TG_SESSION=
#
# TCP tunnel for MTProto (bypass RKN via socat on VPS)
# Ports: DC1=basePort+1, DC2=basePort+2, ... DC5=basePort+5
# TG_TUNNEL_HOST=109.120.187.244
# TG_TUNNEL_BASE_PORT=19150
#
# Channels to monitor (comma-separated usernames or IDs)
# TG_MONITOR_CHANNELS=channel1,channel2
