# ─── Required ─────────────────────────────────────────────
PROXY_AUTH_TOKEN=subbrain-local-dev
PROXY_PORT=4000
DB_PATH=/data/subbrain.db

# ─── LLM Providers ───────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxx
OPENROUTER_API_KEY=sk-or-v1-xxx

# ─── Telegram (for bot & MTProto) ────────────────────────
# Get API ID + Hash at https://my.telegram.org/apps
# TG_API_ID=12345678
# TG_API_HASH=abcdef1234567890abcdef1234567890
#
# Create bot via @BotFather
# TG_BOT_TOKEN=123456:ABC-xxx
#
# Your personal chat ID (get from @userinfobot)
# TG_OWNER_CHAT_ID=123456789
#
# MTProto proxy (optional)
# TG_MTPROTO_SERVER=he.fi.nzcundiuotuumtc5.mtproto.ru
# TG_MTPROTO_PORT=443
# TG_MTPROTO_SECRET=ee211122223333444455556666777788887374726d2d7261642d32332e7374726d2e79616e6465782e6e6574
