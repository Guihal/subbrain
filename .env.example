# ─── Required ─────────────────────────────────────────────
PROXY_AUTH_TOKEN=subbrain-local-dev
PROXY_PORT=4000
DB_PATH=/data/subbrain.db

# ─── Bifrost Gateway ─────────────────────────────────────
BIFROST_ENABLED=false
BIFROST_BASE_URL=http://bifrost:8080
BIFROST_API_KEY=changeme-bifrost-master-key

# ─── Autonomous TeamLead ─────────────────────────────────
# In production it defaults to enabled. Set false to disable.
# AUTONOMOUS_ENABLED=true
# AUTONOMOUS_INTERVAL_MINUTES=15
# AUTONOMOUS_STARTUP_DELAY_MS=30000
# AUTONOMOUS_MAX_STEPS=8
# AUTONOMOUS_TASK is obsolete — startup will throw if set.
# Use POST /v1/tasks scope=autonomous to seed autonomous tasks.

# ─── LLM Providers ───────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxx
# Optional: override if the NeMo Retriever rerank endpoint moves again.
# NVIDIA_RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking
OPENROUTER_API_KEY=sk-or-v1-xxx

# MiniMax Token Plan (platform.minimax.io) — OpenAI-compatible. Primary for
# all LLM roles (teamlead/coder/critic/flash/chaos/generalist/memory).
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=

# ─── OpenAI-compat (CLIProxyAPI / Codex OAuth → ChatGPT Pro) ───
# Routes gpt-5/gpt-5.5/o3/o4/codex-* through a local CLIProxyAPI container,
# which forwards to chatgpt.com using a ChatGPT Pro OAuth token. Off by default.
# Setup on VPS:
#   1. cp cliproxy/config.example.yaml cliproxy/config.yaml
#   2. Replace api-keys[0] in cliproxy/config.yaml with the value below.
#   3. mkdir -p cliproxy/auths && docker compose up -d cliproxy
#   4. docker compose exec cliproxy ./cli-proxy-api --codex-login --no-browser
#      → sign in via your ChatGPT Pro account in the device-flow URL.
#   5. docker compose restart cliproxy
#   6. Set OPENAI_COMPAT_ENABLED=true here, then `docker compose restart subbrain`.
# OPENAI_COMPAT_ENABLED=false
# OPENAI_COMPAT_BASE_URL=http://cliproxy:8317/v1
# OPENAI_COMPAT_API_KEY=replace-with-cliproxy-api-key

# ─── Telegram (Bot API) ──────────────────────────────────
# Get API ID + Hash at https://my.telegram.org/apps (for bot webhook validation)
# TG_API_ID=12345678
# TG_API_HASH=abcdef1234567890abcdef1234567890
#
# Create bot via @BotFather
# TG_BOT_TOKEN=123456:ABC-xxx
#
# Your personal chat ID (get from @userinfobot)
# TG_OWNER_CHAT_ID=123456789
#
# Webhook URL (auto-set on startup): https://yourdomain.com/telegram/webhook
# TG_WEBHOOK_URL=https://subbrain.dmtr.ru/telegram/webhook
# TG_WEBHOOK_SECRET=random-secret-string
#
# Or use polling for local dev (no webhook needed)
# TG_POLLING=true

# ─── Freelance Scout ────────────────────────────────────
# Parallel background scraper for freelance exchanges (fl.ru/kwork/freelance.ru).
# Off by default; turn on deliberately. Incognito Playwright context, 30 req/h per domain.
# FREELANCE_SCOUT=false
# FREELANCE_POLL_MIN=30
# FREELANCE_CATEGORIES=web,backend,bots,scripts
# FREELANCE_MIN_BUDGET=2000
# FREELANCE_MAX_BUDGET=30000
# FREELANCE_THRESHOLD=7
# FREELANCE_TG_CHAT_ID=

# ─── Free Agent (curious autonomous loop) ───────────────
# Parallel to AUTONOMOUS: open-ended, exploration-oriented, TG digest on finish.
# Shares the main Playwright browser. Off by default — turn on when you want
# the system to spend compute on its own curiosity.
# FREE_AGENT=false
# FREE_AGENT_INTERVAL_MIN=60
# FREE_AGENT_STARTUP_DELAY_MS=60000
# FREE_AGENT_MAX_STEPS=50
# FREE_AGENT_TASK=  # override default curiosity prompt

# ─── Agent Pool ─────────────────────────────────────────
# Agent pool digest cron hour (local time). Default 09:00.
# AGENT_POOL_DIGEST_HOUR_LOCAL=9

# ─── OpenTelemetry ────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
